# Copy this file to .env and fill in values before running docker-compose up.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,web

# PostgreSQL
DB_NAME=nano_backbone
DB_USER=nano_backbone
DB_PASSWORD=nano_backbone
DB_HOST=db
DB_PORT=5432

# MinIO / S3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=firmware
AWS_S3_ENDPOINT_URL=http://minio:9000
# Public-facing MinIO URL for presigned download links (must be reachable by devices/clients).
# In dev: http://localhost:9000. In production with real S3: leave unset.
AWS_S3_PRESIGNED_ENDPOINT_URL=http://localhost:9000
